# Hotel System Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file (it is gitignored).

# Local MySQL Database Connection
# Format: mysql+pymysql://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=mysql+pymysql://root:your_local_password@localhost/hotel_system

# JWT settings - MUST set a strong random SECRET_KEY in production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# API settings
API_V1_STR=/api
PROJECT_NAME=Hotel Management System

# Optional: production frontend URL for CORS
# FRONTEND_URL=https://your-hotel-domain.com

# --- PRODUCTION / HOSTING ONLY (leave unset for local development) ---
# Set ENVIRONMENT=production on the server to hide the /docs and /redoc API pages.
# ENVIRONMENT=production
# Allow your live website + admin domains to call the API (comma-separated):
# CORS_ORIGINS=https://your-hotel-domain.com,https://admin.your-hotel-domain.com
# Server bind settings (only used if you start with `python run.py` instead of gunicorn):
# HOST=0.0.0.0
# RELOAD=false

# Email SMTP Settings (For Gmail, use an App Password, not your account password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TITLE=Eva Group Hotel Management
ADMIN_EMAIL=your-admin-email@example.com

# Midtrans Payment Gateway
# Get keys at dashboard.midtrans.com (Settings -> Access Keys).
# Use SANDBOX keys for testing; keep MIDTRANS_IS_PRODUCTION=false until live.
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_CLIENT_KEY=your-client-key
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_IS_PRODUCTION=false
