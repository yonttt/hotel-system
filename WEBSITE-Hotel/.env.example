# Backend API base URL (defaults to http://localhost:8000 if unset)
VITE_API_URL=http://localhost:8000

# EmailJS — sends the "new booking" notification to the hotel.
# All three are PUBLIC values from your EmailJS dashboard (safe in the frontend).
# Create a free account at https://www.emailjs.com/, connect your Gmail as a
# "Service", create an email "Template", then copy the IDs below.
VITE_EMAILJS_SERVICE_ID=
# Staff/hotel "new booking" notification template
VITE_EMAILJS_TEMPLATE_ID=
# Guest "booking confirmation" template
VITE_EMAILJS_TEMPLATE_ID_GUEST=
VITE_EMAILJS_PUBLIC_KEY=
